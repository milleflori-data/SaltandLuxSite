<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#f5f2ec;--warm:#e8e3d8;--sand:#bdbaaf;--stone:#a29f94;
  --umber:#6b6459;--bark:#4a4239;--white:#ffffff;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'Jost',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--umber);font-family:var(--sans);font-weight:300;overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.4rem 3rem;background:rgba(245,242,236,0.92);backdrop-filter:blur(8px);border-bottom:1px solid rgba(189,186,175,0.4)}
.nav-logo{font-family:var(--serif);font-size:1.4rem;font-weight:600;letter-spacing:0.04em;color:var(--umber);text-decoration:none}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{font-size:0.72rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone);text-decoration:none;transition:color 0.25s}
.nav-links a:hover{color:var(--umber)}
section{min-height:100vh;display:flex;align-items:center}
#hero{display:grid;grid-template-columns:1fr 1fr;position:relative;overflow:hidden}
.hero-left{display:flex;flex-direction:column;justify-content:flex-end;padding:8rem 4rem 6rem 5rem;position:relative;z-index:2}
.hero-eyebrow{font-size:0.68rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:var(--stone);margin-bottom:1.6rem}
.hero-title{font-family:var(--serif);font-size:clamp(3.2rem,5.5vw,5.8rem);font-weight:300;line-height:1.05;letter-spacing:-0.01em;color:var(--bark);text-transform:uppercase;margin-bottom:2rem}
.hero-title em{font-style:italic;font-weight:300;color:var(--umber)}
.hero-sub{font-size:0.9rem;font-weight:300;line-height:1.8;color:var(--stone);max-width:380px;margin-bottom:3rem}
.btn{display:inline-block;padding:1rem 2.6rem;background:var(--umber);color:var(--cream);font-family:var(--sans);font-size:0.68rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;border:1px solid var(--umber);transition:background 0.3s,color 0.3s;width:fit-content}
.btn:hover{background:transparent;color:var(--umber)}
.btn-outline{background:transparent;color:var(--umber)}
.btn-outline:hover{background:var(--umber);color:var(--cream)}
.hero-right{position:relative;overflow:hidden;background:var(--warm)}
.hero-img{width:100%;height:100%;min-height:100vh;object-fit:cover;display:block}
.hero-placeholder{width:100%;height:100%;min-height:100vh;background:var(--warm);display:flex;align-items:center;justify-content:center;position:relative}
.hero-placeholder::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 40px,rgba(189,186,175,0.15) 40px,rgba(189,186,175,0.15) 41px)}
.hero-brand{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);font-family:var(--serif);font-size:0.7rem;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:var(--umber);text-decoration:underline;text-underline-offset:4px}
.section-tag{font-size:0.65rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:var(--sand);margin-bottom:1.2rem}
.section-title{font-family:var(--serif);font-size:clamp(2.4rem,4vw,4.4rem);font-weight:300;line-height:1.05;text-transform:uppercase;color:var(--bark);margin-bottom:1.8rem}
.section-body{font-size:0.9rem;line-height:1.9;color:var(--stone);max-width:480px}
.section-body strong{font-weight:500;color:var(--umber)}
.ornament{display:block;width:40px;height:1px;background:var(--sand);margin:2rem 0}
.img-panel{background:var(--warm);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.img-panel::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-45deg,transparent,transparent 30px,rgba(189,186,175,0.1) 30px,rgba(189,186,175,0.1) 31px);pointer-events:none}
.img-panel img{width:100%;height:100%;object-fit:cover;display:block;position:relative;z-index:1}
#commitment{background:var(--cream)}
.commitment-inner{display:grid;grid-template-columns:1fr 1fr;width:100%;min-height:100vh}
.commitment-img{height:100%;min-height:100vh}
.commitment-img img{width:100%;height:100%;object-fit:cover;display:block}
.commitment-content{display:flex;flex-direction:column;justify-content:center;padding:6rem 5rem 6rem 4rem}
.commitment-icon{width:52px;height:52px;margin-bottom:2rem;opacity:0.6}
#services{background:var(--cream)}
.services-inner{display:grid;grid-template-columns:1fr 1fr;width:100%;min-height:100vh}
.services-content{display:flex;flex-direction:column;justify-content:center;padding:6rem 4rem 6rem 5rem}
.services-images{display:grid;grid-template-rows:1fr 1fr;gap:2px;min-height:100vh}
.services-images .img-panel{height:100%}
.svc-item{border-left:2px solid var(--sand);padding-left:1.2rem;margin-bottom:1.2rem}
.svc-label{font-size:0.7rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--umber);margin-bottom:0.3rem}
.svc-text{font-size:0.82rem;color:var(--stone);line-height:1.6}
#why{background:var(--warm)}
.why-inner{width:100%;max-width:1300px;margin:0 auto;padding:8rem 5rem;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
.why-img{height:520px;overflow:hidden;border-radius:2px}
.why-features{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;margin-top:2.5rem}
.why-feature{border-top:1px solid var(--sand);padding-top:1.2rem}
.why-num{font-family:var(--serif);font-size:2rem;font-weight:300;color:var(--sand);margin-bottom:0.5rem}
.why-ftitle{font-size:0.72rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--umber);margin-bottom:0.5rem}
.why-ftext{font-size:0.82rem;line-height:1.7;color:var(--stone)}
#testimonials{background:var(--cream);flex-direction:column;justify-content:center}
.testimonials-inner{width:100%;max-width:1300px;margin:0 auto;padding:8rem 5rem}
.testimonials-header{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-bottom:5rem;align-items:end}
.testimonials-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.tcard{background:var(--warm);padding:3rem;display:flex;flex-direction:column;justify-content:space-between}
.tquote{font-family:var(--serif);font-size:1.25rem;font-weight:300;font-style:italic;line-height:1.7;color:var(--bark);margin-bottom:2rem}
.tauthor{font-size:0.68rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone)}
.stars{color:var(--sand);font-size:0.9rem;letter-spacing:0.1em;margin-bottom:1.2rem}
.timg{height:320px;overflow:hidden}
.timg img{width:100%;height:100%;object-fit:cover}
#process{background:var(--bark);color:var(--cream);flex-direction:column;justify-content:center}
.process-inner{width:100%;max-width:1300px;margin:0 auto;padding:8rem 5rem}
#process .section-title{color:var(--cream)}
#process .section-tag{color:var(--sand);opacity:.7}
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3rem;margin-top:4rem}
.pstep{border-top:1px solid rgba(189,186,175,0.3);padding-top:1.5rem}
.pnum{font-family:var(--serif);font-size:3rem;font-weight:300;color:rgba(189,186,175,0.3);line-height:1;margin-bottom:1rem}
.ptitle{font-size:0.72rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--cream);margin-bottom:0.8rem}
.ptext{font-size:0.82rem;line-height:1.8;color:var(--stone)}
.process-img-row{margin-top:4rem;height:280px;overflow:hidden;border-radius:2px}
.process-img-row img{width:100%;height:100%;object-fit:cover;display:block}
#booking{background:var(--umber);color:var(--cream);flex-direction:column;justify-content:center;align-items:center;text-align:center;position:relative;overflow:hidden}
.booking-bg{position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 60px,rgba(245,242,236,0.04) 60px,rgba(245,242,236,0.04) 61px),repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(245,242,236,0.04) 60px,rgba(245,242,236,0.04) 61px)}
.booking-inner{position:relative;z-index:2;max-width:700px;padding:6rem 3rem}
#booking .section-tag{color:rgba(245,242,236,0.5)}
#booking .section-title{color:var(--cream)}
#booking .section-body{color:rgba(245,242,236,0.7);max-width:100%;margin:0 auto 3rem}
.btn-light{background:var(--cream);color:var(--umber);border-color:var(--cream)}
.btn-light:hover{background:transparent;color:var(--cream)}
#contact{background:var(--cream);flex-direction:column;justify-content:center}
.contact-inner{width:100%;max-width:1300px;margin:0 auto;padding:8rem 5rem;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start}
.contact-title{font-family:var(--serif);font-size:clamp(3rem,5vw,6rem);font-weight:300;text-transform:uppercase;line-height:1;color:var(--bark);margin-bottom:3rem}
.cdetail{border-top:1px solid var(--warm);padding:1.5rem 0}
.clabel{font-size:0.65rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--sand);margin-bottom:0.4rem}
.cvalue{font-size:0.95rem;color:var(--umber)}
.contact-imgs{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.contact-imgs .img-panel{height:280px}
footer{background:var(--bark);color:var(--stone);padding:3rem 5rem;display:flex;justify-content:space-between;align-items:center;font-size:0.72rem;letter-spacing:0.08em}
.footer-logo{font-family:var(--serif);font-size:1.2rem;font-weight:600;color:var(--cream);letter-spacing:0.04em}
.reveal{opacity:0;transform:translateY(28px);transition:opacity 0.8s ease,transform 0.8s ease}
.reveal.visible{opacity:1;transform:none}
.reveal-delay-1{transition-delay:0.15s}
.reveal-delay-2{transition-delay:0.3s}
.reveal-delay-3{transition-delay:0.45s}
@media(max-width:900px){
  nav{padding:1.2rem 1.5rem}
  .nav-links{display:none}
  #hero,.commitment-inner,.services-inner,.why-inner,.contact-inner{grid-template-columns:1fr}
  .hero-left{padding:7rem 2rem 4rem}
  .hero-right,.commitment-img{min-height:50vh}
  .commitment-content,.services-content{padding:3rem 2rem}
  .services-images{height:60vw;grid-template-rows:1fr;grid-template-columns:1fr 1fr}
  .why-inner,.testimonials-inner,.process-inner,.contact-inner{padding:5rem 2rem}
  .why-img{height:300px}
  .process-grid{grid-template-columns:1fr 1fr}
  .testimonials-header,.testimonials-grid,.contact-imgs{grid-template-columns:1fr}
  .contact-imgs .img-panel{height:200px}
  footer{flex-direction:column;gap:1rem;text-align:center;padding:2rem}
}
</style>
</head>
<body>

